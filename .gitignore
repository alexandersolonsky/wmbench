# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv*/
venv/

# wmbench build output (regenerated by CI from committed results)
site/

# Input image corpus is user-provided / generated locally — not committed.
# Only results/ (results.json, results.csv, sample thumbnails) is tracked.
data/images/

# Model weights / checkpoints (download on the benchmark machine)
checkpoints/
*.pth
*.ckpt

# Editor / local tooling
.claude/

# Stray asset tree created by a backend install (TrustMark/vmaf samples) — not ours
img/

# OS
.DS_Store

# Intermediate per-algorithm benchmark runs (merged into results/)
.runs/
vendor/

# PixelSeal checkpoint download dir
ckpts/

# Large generated gallery assets + local result backups (regenerated locally;
# only results.json / results.csv are tracked)
results/gallery/
results/samples/
results/*_full103.json

# Curated CC-BY image set kept local, like img/ (not bundled — attribution req'd)
img_pruned/

# Cloudflare wrangler local cache
.wrangler/
